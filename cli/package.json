{
  "name": "boa-cli",
  "version": "0.1.0",
  "description": "CLI for BOA (Backend on AWS) serverless backends",
  "type": "module",
  "bin": {
    "boa": "./bin/boa.mjs"
  },
  "scripts": {
    "sync:skill": "node scripts/sync-skill.mjs",
    "prepack": "node scripts/sync-skill.mjs",
    "prepublishOnly": "node scripts/sync-skill.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "commands/",
    "extensions/",
    "lib/",
    "skill/",
    "templates/"
  ],
  "keywords": [
    "aws",
    "serverless",
    "backend",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.700.0",
    "cli-table3": "^0.6.5",
    "listr2": "^10.2.1",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.3"
  }
}
