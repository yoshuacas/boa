// league_admin.cedar — League admin management

// Authenticated users can create leagues
permit(
    principal is PgrestLambda::User,
    action == PgrestLambda::Action::"insert",
    resource is PgrestLambda::Table
) when {
    resource == PgrestLambda::Table::"leagues"
};

// League creators can update their own leagues
permit(
    principal is PgrestLambda::User,
    action == PgrestLambda::Action::"update",
    resource is PgrestLambda::Row
) when {
    resource in PgrestLambda::Table::"leagues" &&
    resource has created_by && resource.created_by == principal
};

// Authenticated users can insert league_admins (league creator adds admins)
permit(
    principal is PgrestLambda::User,
    action == PgrestLambda::Action::"insert",
    resource is PgrestLambda::Table
) when {
    resource == PgrestLambda::Table::"league_admins"
};

// League admins can read the league_admins table
permit(
    principal is PgrestLambda::User,
    action == PgrestLambda::Action::"select",
    resource is PgrestLambda::Row
) when {
    resource in PgrestLambda::Table::"league_admins"
};

// League admins can delete league_admin entries they own
permit(
    principal is PgrestLambda::User,
    action == PgrestLambda::Action::"delete",
    resource is PgrestLambda::Row
) when {
    resource in PgrestLambda::Table::"league_admins" &&
    resource has user_id && resource.user_id == principal
};
